# =========================
# Backend (Django / Python)
# =========================
# Virtual environments
venv/
env/

# Compiled Python files
__pycache__/
*.pyc
*.pyo
*.pyd

# Local database (do not commit test data)
db.sqlite3

# Environment variables (for secrets or API keys)
.env

# =========================
# Frontend (React / Vite)
# =========================
# Node dependencies (never commit these)
node_modules/
frontend/node_modules/

# Vite build output
dist/
dist-ssr/
build/

# Frontend environment variables
.env.local
.env.*.local

# =========================
# OS & editor settings
# =========================
# macOS hidden files
.DS_Store

# Windows hidden files
Thumbs.db

# Editor settings
.vscode/
.idea/