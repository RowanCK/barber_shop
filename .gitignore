# =========================
# Backend (Django / Python)
# =========================
# 虛擬環境
venv/
env/

# 編譯後的 Python 檔案
__pycache__/
*.pyc
*.pyo
*.pyd

# 本機資料庫 (不要把你的測試資料傳上去)
db.sqlite3

# 環境變數 (未來用來放密碼或 API Key 的地方)
.env

# =========================
# Frontend (React / Vite)
# =========================
# Node 依賴套件 (這絕對不能傳！)
node_modules/
frontend/node_modules/

# Vite 編譯輸出的靜態檔案
dist/
dist-ssr/
build/

# 前端環境變數
.env.local
.env.*.local

# =========================
# OS & 編輯器設定檔
# =========================
# Mac 系統隱藏檔
.DS_Store

# Windows 系統隱藏檔
Thumbs.db

# 編輯器設定檔
.vscode/
.idea/